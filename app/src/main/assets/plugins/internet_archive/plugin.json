{
  "schema": 1,
  "id": "internet_archive",
  "name": "Internet Archive",
  "version": "1.0.0",
  "siteUrl": "https://archive.org",
  "mediaTypes": ["movie", "tv"],
  "search": {
    "url": "https://archive.org/advancedsearch.php?q=({query})%20AND%20mediatype:(movies)&fl%5B%5D=identifier&fl%5B%5D=title&fl%5B%5D=description&rows=24&page=1&output=json",
    "resultsPath": "response.docs",
    "idPath": "identifier",
    "titlePath": "title",
    "descriptionPath": "description",
    "posterTemplate": "https://archive.org/services/img/{id}"
  },
  "details": {
    "url": "https://archive.org/metadata/{id}",
    "titlePath": "metadata.title",
    "descriptionPath": "metadata.description",
    "posterTemplate": "https://archive.org/services/img/{id}",
    "streamsPath": "files",
    "streamUrlTemplate": "https://archive.org/download/{id}/{name}",
    "streamQualityPath": "format",
    "streamType": "stream",
    "streamExtensions": [".mp4", ".m4v", ".webm", ".ogv"]
  }
}
